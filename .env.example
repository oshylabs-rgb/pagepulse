# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Gemini (AI for SEO analysis)
GEMINI_API_KEY=your_gemini_api_key
# Optional: which Gemini model to use for SEO analysis. Defaults to
# gemini-1.5-flash, which is broadly available. Some models (e.g.
# gemini-2.5-flash) may return 403 PERMISSION_DENIED for a given API key
# or Google Cloud project even when the key itself is valid — switch
# GEMINI_MODEL to a model your project has access to, or generate a new
# API key in a project that has access enabled.
# GEMINI_MODEL=gemini-1.5-flash

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_AGENCY_PRICE_ID=price_...

# Resend (email)
RESEND_API_KEY=re_...
# REQUIRED in production: a sender address on a domain you have verified at
# https://resend.com/domains. While EMAIL_FROM is unset OR points to a
# non-verified domain, Resend rejects emails to any recipient other than the
# Resend account owner's own address (test mode). When EMAIL_FROM is not
# set the app falls back to onboarding@resend.dev (Resend's shared sandbox
# sender) which is suitable for local development only.
EMAIL_FROM=PagePulse <noreply@pagepulse.se>
# Optional: separate sender for monitoring alerts. Defaults to EMAIL_FROM.
EMAIL_ALERTS_FROM=PagePulse Alerts <alerts@pagepulse.se>

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
